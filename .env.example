# App
NODE_ENV=development
PORT=3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_this_super_secret

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# DB
DATABASE_URL=postgresql://aniforge:aniforge_password@localhost:5432/aniforge?schema=public
POSTGRES_DB=aniforge
POSTGRES_USER=aniforge
POSTGRES_PASSWORD=aniforge_password

# Plan bootstrap
ADMIN_EMAIL=admin@aniforge.local

# Redis
REDIS_URL=redis://localhost:6379

# Volumes for docker compose
NVME_POSTGRES_DATA=/mnt/nvme/aniforge/postgres
NVME_REDIS_DATA=/mnt/nvme/aniforge/redis
HDD_BACKUPS_DIR=/mnt/hdd/backups/aniforge
HDD_LOGS_DIR=/mnt/hdd/logs/aniforge-nginx
